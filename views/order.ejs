<!doctype html>
<html>
<head><title>Menu · Beanline</title><%- include('partials-head') %>
<style>
  .categories { display: flex; gap: 8px; margin-bottom: 22px; flex-wrap: wrap; }
  .category-pill {
    padding: 7px 15px;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--line);
    font-size: 12.5px;
    font-weight: 600;
    color: var(--ink-soft);
    cursor: pointer;
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .category-pill.active { background: var(--espresso); color: var(--gold); border-color: var(--espresso); }

  .content { display: flex; gap: 24px; align-items: flex-start; }
  .menu-grid {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }
  .menu-card {
    background: #fff;
    border-radius: 12px;
    padding: 16px;
    border: 1px solid var(--line);
    opacity: 0;
    animation: rise 0.35s ease forwards;
  }
  .menu-card:nth-child(1) { animation-delay: 0.02s; }
  .menu-card:nth-child(2) { animation-delay: 0.06s; }
  .menu-card:nth-child(3) { animation-delay: 0.10s; }
  .menu-card:nth-child(4) { animation-delay: 0.14s; }
  .menu-card:nth-child(5) { animation-delay: 0.18s; }
  .menu-card:nth-child(6) { animation-delay: 0.22s; }

  .menu-card-top { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 12px; }
  .menu-icon {
    width: 42px; height: 42px; border-radius: 10px;
    background: var(--parchment-2);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: var(--cherry);
  }
  .menu-icon svg { width: 21px; height: 21px; }
  .menu-card-photo { width: 52px; height: 52px; border-radius: 10px; object-fit: cover; flex-shrink: 0; border: 1px solid var(--line); }
  .menu-card-photo.placeholder { display: flex; align-items: center; justify-content: center; background: var(--parchment-2); color: var(--cherry); }
  .menu-card-photo.placeholder svg { width: 21px; height: 21px; }
  .menu-name { font-family: var(--font-display); font-weight: 600; font-size: 15.5px; line-height: 1.2; }
  .menu-note { font-size: 12px; color: var(--ink-soft); margin-top: 3px; line-height: 1.35; }
  .menu-price { font-family: var(--font-mono); color: var(--gold-deep); font-weight: 500; font-size: 13.5px; margin-top: 6px; }

  .qty-row { display: flex; align-items: center; justify-content: space-between; margin-top: 12px; padding-top: 12px; border-top: 1px dashed var(--line); }
  .qty-label { font-size: 11.5px; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-soft); font-weight: 600; }
  .stepper { display: flex; align-items: center; gap: 10px; }
  .stepper button {
    width: 24px; height: 24px; border-radius: 50%; border: 1px solid var(--line);
    background: #fff; cursor: pointer; font-size: 14px; line-height: 1; color: var(--ink-soft);
    display: flex; align-items: center; justify-content: center;
  }
  .stepper button:hover { border-color: var(--gold); color: var(--gold-deep); }
  .stepper .qty-val { min-width: 14px; text-align: center; font-weight: 600; font-family: var(--font-mono); font-size: 13px; }
  .add-btn {
    width: 100%; margin-top: 12px; padding: 9px; border-radius: 8px; border: 1px solid var(--espresso);
    background: var(--espresso); color: var(--gold); font-weight: 600; font-size: 12.5px; cursor: pointer;
    transition: transform 0.1s ease;
  }
  .add-btn:hover { background: var(--espresso-2); }
  .add-btn:active { transform: scale(0.97); }
  .add-btn.just-added { background: var(--gold); border-color: var(--gold); color: var(--espresso); }

  .no-results { grid-column: 1 / -1; text-align: center; color: var(--ink-soft); padding: 40px 0; font-size: 14px; }

  /* Bill / receipt panel */
  .bill-panel { width: 300px; flex-shrink: 0; position: sticky; top: 30px; }
  .bill-empty { color: var(--ink-soft); font-size: 13px; padding: 6px 0 2px; }
  .bill-item {
    display: flex; justify-content: space-between; align-items: flex-start;
    font-family: var(--font-mono); font-size: 12.5px; color: var(--ink);
    padding: 7px 0;
  }
  .bill-item .qty-name { flex: 1; padding-right: 8px; }
  .bill-item .remove {
    background: none; border: none; color: var(--cherry); cursor: pointer;
    font-family: var(--font-body); font-size: 11px; padding: 0; margin-left: 8px; text-decoration: underline;
  }
  .bill-totals-wrap {
    background: #fffdf8;
    border: 1px solid var(--line);
    border-top: none;
    padding: 4px 20px 20px;
  }
  .bill-totals .row { display: flex; justify-content: space-between; font-size: 12.5px; color: var(--ink-soft); margin-top: 6px; font-family: var(--font-mono); }
  .bill-totals .row.total { font-weight: 600; font-size: 16px; color: var(--ink); margin-top: 10px; padding-top: 10px; border-top: 1px solid var(--line); }
  .process-btn {
    width: 100%; margin-top: 16px; padding: 12px; border-radius: 9px; border: none;
    background: var(--gold); color: var(--espresso); font-weight: 700; font-size: 14px; cursor: pointer;
    transition: background 0.15s ease, transform 0.1s ease;
  }
  .process-btn:hover:not(:disabled) { background: var(--gold-deep); }
  .process-btn:active:not(:disabled) { transform: scale(0.98); }
  .process-btn:disabled { background: var(--parchment-2); color: var(--ink-soft); cursor: not-allowed; }
  .order-error { color: var(--cherry-deep); background: rgba(156,59,44,0.08); border: 1px solid rgba(156,59,44,0.3); padding: 10px 14px; border-radius: 8px; font-size: 13.5px; margin-bottom: 16px; }

  @media (max-width: 860px) {
    .content { flex-direction: column; }
    .bill-panel { width: 100%; position: static; }
  }
</style>
</head>
<body>
  <div class="app-shell">
    <div class="app-sidebar">
      <div class="app-mark">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 8h13a3 3 0 0 1 0 6h-1"/><path d="M4 8v7a4 4 0 0 0 4 4h5a4 4 0 0 0 4-4V8"/><path d="M8 2.5c0 1-1 1.2-1 2.2s1 1.2 1 2.2M12.5 2.5c0 1-1 1.2-1 2.2s1 1.2 1 2.2"/></svg>
        <span>Beanline</span>
      </div>
      <a class="app-nav-item active" href="/<%= shop.slug %>/order">Menu</a>
      <div class="app-sidebar-foot">
        <div class="who"><%= user.name %></div>
        <a href="/logout">Log out</a>
      </div>
    </div>

    <div class="app-main">
      <div class="app-topbar">
        <div class="app-search">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" id="menu-search" placeholder="Search the menu…" autocomplete="off">
        </div>
        <div class="app-user">
          <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
          <span><%= user.name %></span>
        </div>
      </div>

      <h1 style="font-size:28px; margin-bottom:18px;">Today's menu</h1>
      <% if (error) { %><p class="order-error"><%= error %></p><% } %>

      <% if (menu.length === 0) { %>
        <div class="empty-state">
          <h3>No items yet</h3>
          <p>This shop hasn't added anything to their menu yet.</p>
        </div>
      <% } else { %>
      <% const categories = [...new Set(menu.map((i) => i.category))]; %>
      <div class="categories" id="categories">
        <div class="category-pill active" data-category="all">All</div>
        <% categories.forEach((cat) => { %>
          <div class="category-pill" data-category="<%= cat %>"><%= cat %></div>
        <% }) %>
      </div>

      <div class="content">
        <div class="menu-grid" id="menu-grid">
          <% menu.forEach(item => { %>
            <div class="menu-card" data-category="<%= item.category %>" data-name="<%= item.name.toLowerCase() %>">
              <div class="menu-card-top">
                <% if (item.image_url) { %>
                  <img class="menu-card-photo" src="<%= item.image_url %>" alt="">
                <% } else { %>
                  <div class="menu-card-photo placeholder"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 8h13a3 3 0 0 1 0 6h-1"/><path d="M4 8v7a4 4 0 0 0 4 4h5a4 4 0 0 0 4-4V8"/></svg></div>
                <% } %>
                <div>
                  <div class="menu-name"><%= item.name %></div>
                  <div class="menu-note"><%= item.note %></div>
                  <div class="menu-price">$<%= item.price.toFixed(2) %></div>
                </div>
              </div>
              <div class="qty-row">
                <span class="qty-label">Qty</span>
                <div class="stepper">
                  <button type="button" class="minus" data-id="<%= item.id %>" aria-label="Decrease quantity">&minus;</button>
                  <span class="qty-val" id="qty-<%= item.id %>">1</span>
                  <button type="button" class="plus" data-id="<%= item.id %>" aria-label="Increase quantity">+</button>
                </div>
              </div>
              <button type="button" class="add-btn"
                data-id="<%= item.id %>" data-name="<%= item.name %>" data-price="<%= item.price %>">
                Add to order
              </button>
            </div>
          <% }) %>
          <p class="no-results" id="no-results" hidden>Nothing matches that search.</p>
        </div>

        <div class="bill-panel">
          <div class="receipt">
            <h2>Your order</h2>
            <div id="bill-list"><p class="bill-empty">Nothing added yet — pick something on the left.</p></div>
          </div>
          <div class="bill-totals-wrap">
            <div class="bill-totals">
              <div class="row"><span>Items</span><span id="bill-count">0</span></div>
              <div class="row total"><span>Total</span><span id="bill-total">$0.00</span></div>
            </div>
            <form method="POST" action="/<%= shop.slug %>/order" id="order-form">
              <div id="hidden-inputs"></div>
              <button type="submit" class="process-btn" id="process-btn" disabled>Place order</button>
            </form>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </div>

  <script>
    const cart = {};
    const stepperQty = {};

    function applyFilters() {
      const activeCat = document.querySelector('.category-pill.active').dataset.category;
      const query = document.getElementById('menu-search').value.trim().toLowerCase();
      let visibleCount = 0;
      document.querySelectorAll('.menu-card').forEach(card => {
        const matchesCat = activeCat === 'all' || card.dataset.category === activeCat;
        const matchesQuery = !query || card.dataset.name.includes(query);
        const show = matchesCat && matchesQuery;
        card.style.display = show ? '' : 'none';
        if (show) visibleCount++;
      });
      document.getElementById('no-results').hidden = visibleCount > 0;
    }

    document.querySelectorAll('.category-pill').forEach(pill => {
      pill.addEventListener('click', () => {
        document.querySelectorAll('.category-pill').forEach(p => p.classList.remove('active'));
        pill.classList.add('active');
        applyFilters();
      });
    });
    document.getElementById('menu-search').addEventListener('input', applyFilters);

    document.querySelectorAll('.stepper .minus').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        const current = stepperQty[id] || 1;
        stepperQty[id] = Math.max(1, current - 1);
        document.getElementById('qty-' + id).textContent = stepperQty[id];
      });
    });
    document.querySelectorAll('.stepper .plus').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        const current = stepperQty[id] || 1;
        stepperQty[id] = current + 1;
        document.getElementById('qty-' + id).textContent = stepperQty[id];
      });
    });

    document.querySelectorAll('.add-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = btn.dataset.id;
        const name = btn.dataset.name;
        const price = parseFloat(btn.dataset.price);
        const qty = stepperQty[id] || 1;
        if (cart[id]) {
          cart[id].qty += qty;
        } else {
          cart[id] = { name, price, qty };
        }
        renderBill();
        btn.textContent = 'Added';
        btn.classList.add('just-added');
        setTimeout(() => { btn.textContent = 'Add to order'; btn.classList.remove('just-added'); }, 900);
      });
    });

    function removeFromCart(id) {
      delete cart[id];
      renderBill();
    }

    function renderBill() {
      const billList = document.getElementById('bill-list');
      const hiddenInputs = document.getElementById('hidden-inputs');
      const ids = Object.keys(cart);

      hiddenInputs.innerHTML = '';
      if (ids.length === 0) {
        billList.innerHTML = '<p class="bill-empty">Nothing added yet — pick something on the left.</p>';
        document.getElementById('bill-count').textContent = '0';
        document.getElementById('bill-total').textContent = '$0.00';
        document.getElementById('process-btn').disabled = true;
        return;
      }

      let total = 0;
      let count = 0;
      billList.innerHTML = ids.map(id => {
        const item = cart[id];
        total += item.price * item.qty;
        count += item.qty;
        return `<div class="receipt-line bill-item">
          <span class="qty-name">${item.name} &times;${item.qty}</span>
          <span class="dots"></span>
          <span>$${(item.price * item.qty).toFixed(2)}</span>
          <button type="button" class="remove" onclick="removeFromCart('${id}')">remove</button>
        </div>`;
      }).join('');

      ids.forEach(id => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'qty_' + id;
        input.value = cart[id].qty;
        hiddenInputs.appendChild(input);
      });

      document.getElementById('bill-count').textContent = count;
      document.getElementById('bill-total').textContent = '$' + total.toFixed(2);
      document.getElementById('process-btn').disabled = false;
    }
  </script>
</body>
</html>
