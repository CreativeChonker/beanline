<!doctype html>
<html>
<head><title>Edit <%= item.name %> · Beanline</title><%- include('partials-head') %></head>
<body>
  <div class="app-shell">
    <%- include('partials-sidebar', { active: 'menu' }) %>
    <div class="app-main">
      <div class="app-topbar">
        <h1 style="font-size:26px;">Edit item</h1>
      </div>
      <% if (error) { %><p class="form-error"><%= error %></p><% } %>
      <div class="panel" style="max-width:480px;">
        <form method="POST" action="/menu/<%= item.id %>">
          <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" value="<%= item.name %>" required></div>
          <div class="field"><label for="category">Category</label><input id="category" name="category" type="text" value="<%= item.category %>" required></div>
          <div class="field"><label for="itemType">Type</label>
            <select id="itemType" name="itemType">
              <option value="drink" <%= item.item_type === 'drink' ? 'selected' : '' %>>Drink</option>
              <option value="food" <%= item.item_type === 'food' ? 'selected' : '' %>>Food</option>
            </select>
          </div>
          <div class="field"><label for="price">Price (S / base)</label><input id="price" name="price" type="number" step="0.01" min="0.01" value="<%= item.price %>" required></div>
          <div class="field"><label for="priceMedium">Price M (blank = no Medium)</label>
            <input id="priceMedium" name="priceMedium" type="number" step="0.01" min="0.01" value="<%= item.price_medium ?? '' %>"></div>
          <div class="field"><label for="priceLarge">Price L (blank = no Large)</label>
            <input id="priceLarge" name="priceLarge" type="number" step="0.01" min="0.01" value="<%= item.price_large ?? '' %>"></div>
          <div class="field"><label for="note">Note</label><input id="note" name="note" type="text" value="<%= item.note %>"></div>
          <button type="submit" class="btn btn-primary">Save</button>
        </form>
      </div>
      <p class="panel-foot"><a href="/menu">Back to menu</a></p>
    </div>
  </div>
</body>
</html>
