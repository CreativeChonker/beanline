<!doctype html>
<html>
<head><title>Edit <%= item.name %> · Beanline</title><%- include('partials-head') %></head>
<body>
  <div class="app-shell">
    <%- include('partials-sidebar', { active: 'menu' }) %>
    <div class="app-main">
      <div class="app-topbar">
        <h1 style="font-size:26px;">Edit item</h1>
      </div>
      <% if (error) { %><p class="form-error"><%= error %></p><% } %>
      <div class="panel" style="max-width:480px;">
        <form method="POST" action="/menu/<%= item.id %>" enctype="multipart/form-data">
          <div class="field"><label for="name">Name</label><input id="name" name="name" type="text" value="<%= item.name %>" required></div>
          <div class="field"><label for="categorySelect">Category</label>
            <select id="categorySelect" name="categoryId">
              <% categories.forEach((c) => { %>
                <option value="<%= c.id %>" data-tiers="<%= JSON.stringify(c.tier_names) %>"<%= c.id === item.category_id ? ' selected' : '' %>><%= c.name %><%= c.archived ? ' (archived)' : '' %></option>
              <% }) %>
            </select>
          </div>
          <div class="field" id="field-tier-0"><label for="price" id="tier-label-0">Price</label><input id="price" name="price" type="number" step="0.01" min="0.01" value="<%= item.price %>" required></div>
          <div class="field" id="field-tier-1"><label for="priceMedium" id="tier-label-1">Price</label>
            <input id="priceMedium" name="priceMedium" type="number" step="0.01" min="0.01" value="<%= item.price_medium ?? '' %>"></div>
          <div class="field" id="field-tier-2"><label for="priceLarge" id="tier-label-2">Price</label>
            <input id="priceLarge" name="priceLarge" type="number" step="0.01" min="0.01" value="<%= item.price_large ?? '' %>"></div>
          <div class="field"><label for="note">Description</label><textarea id="note" name="note" rows="3" style="width:100%;padding:11px 12px;border-radius:8px;border:1px solid var(--line);background:#fff;color:var(--ink);font-family:var(--font-body);font-size:14.5px;resize:vertical;"><%= item.note %></textarea></div>
          <div class="field"><label>Photo</label>
            <% if (item.image_url) { %>
              <img src="<%= item.image_url %>" alt="" style="width:96px;height:96px;object-fit:cover;border-radius:10px;border:1px solid var(--line);display:block;margin-bottom:8px;">
            <% } %>
            <input name="itemImage" type="file" accept="image/jpeg,image/png,image/webp">
            <div style="font-size:12px;color:var(--ink-soft);margin-top:4px;">JPG, PNG or WEBP up to 5MB<%= item.image_url ? ' — uploading replaces the current photo' : '' %></div>
          </div>
          <button type="submit" class="btn btn-primary">Save</button>
        </form>
      </div>
      <p class="panel-foot"><a href="/menu">Back to menu</a></p>
      <script>
        const catSelect = document.getElementById('categorySelect');
        const syncTiers = () => {
          const tiers = JSON.parse(catSelect.selectedOptions[0].dataset.tiers);
          for (let i = 0; i < 3; i++) {
            const field = document.getElementById('field-tier-' + i);
            field.style.display = i < tiers.length ? '' : 'none';
            if (i < tiers.length) document.getElementById('tier-label-' + i).textContent = tiers[i] + (tiers.length > 1 ? ' price' : '') + (i > 0 ? ' (blank = not offered)' : '');
          }
        };
        catSelect.addEventListener('change', syncTiers);
        syncTiers();
      </script>
    </div>
  </div>
</body>
</html>
