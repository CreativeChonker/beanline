<% values = typeof values === 'undefined' ? {} : values %>
<!doctype html>
<html>
<head><title>Menu · Beanline</title><%- include('partials-head') %>
<style>
  .menu-sub { color: var(--ink-soft); font-size: 14px; margin: 4px 0 0; }
  .menu-section { background: #fff; border: 1px solid var(--line); border-radius: 14px; margin-bottom: 18px; overflow: hidden; }
  .menu-section-toggle {
    display: flex; align-items: center; gap: 10px; width: 100%;
    padding: 14px 18px; background: #fffdf8; border: none; border-bottom: 1px solid var(--line);
    font-family: var(--font-display); font-weight: 600; font-size: 16px; color: var(--ink);
    cursor: pointer; text-align: left;
  }
  .menu-section-toggle .cat-icon { width: 20px; height: 20px; color: var(--gold-deep); flex-shrink: 0; }
  .menu-section-toggle .count { margin-left: auto; font-family: var(--font-mono); font-size: 12px; font-weight: 400; color: var(--ink-soft); }
  .menu-section-toggle .chev { width: 16px; height: 16px; color: var(--ink-soft); transition: transform 0.2s ease; }
  .menu-section.collapsed .chev { transform: rotate(180deg); }
  .menu-section.collapsed .menu-rows { display: none; }
  .menu-section.collapsed .menu-section-toggle { border-bottom: none; }
  .menu-row { display: flex; align-items: center; gap: 14px; padding: 12px 18px; border-bottom: 1px solid var(--parchment-2); }
  .menu-row:last-child { border-bottom: none; }
  .menu-row.unavailable { opacity: 0.55; }
  .menu-thumb, .menu-thumb-placeholder {
    width: 48px; height: 48px; border-radius: 10px; flex-shrink: 0;
    border: 1px solid var(--line); object-fit: cover;
  }
  .menu-thumb-placeholder { display: flex; align-items: center; justify-content: center; background: var(--parchment); color: var(--line); }
  .menu-thumb-placeholder svg { width: 22px; height: 22px; }
  .menu-row-info { flex: 1; min-width: 0; }
  .col-status { width: 100px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .col-prices { width: 214px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; gap: 14px; }
  .col-size { width: 62px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .col-wide { width: 96px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .price-empty { color: var(--line); font-weight: 400; }
  .col-actions { width: 190px; flex-shrink: 0; justify-content: flex-end; }
  .menu-cols-head {
    display: flex; align-items: center; gap: 14px; padding: 8px 18px;
    background: var(--parchment); border-bottom: 1px solid var(--line);
    font-size: 10.5px; text-transform: uppercase; letter-spacing: 0.08em;
    font-weight: 700; color: var(--ink-soft);
  }
  .menu-cols-head .col-item { flex: 1; }
  .menu-cols-head .col-thumb { width: 48px; flex-shrink: 0; }
  .menu-row-name { font-family: var(--font-display); font-weight: 600; font-size: 15px; }
  .menu-row-note { font-size: 12.5px; color: var(--ink-soft); margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .status-pill { display: inline-block; flex-shrink: 0; font-size: 11.5px; font-weight: 600; padding: 3px 10px; border-radius: 999px; background: rgba(62,125,79,0.14); color: var(--green-deep); border: 1px solid rgba(62,125,79,0.25); }
  .status-pill.sold-out { background: rgba(156,59,44,0.12); color: var(--cherry-deep); border-color: rgba(156,59,44,0.3); }
  .menu-row-price { font-family: var(--font-mono); font-size: 14.5px; color: var(--ink); font-weight: 700; white-space: nowrap; }
  .menu-row-actions { display: flex; gap: 6px; flex-shrink: 0; position: relative; }
  .menu-row-actions form { display: inline; }
  .btn-small { padding: 7px 13px; border-radius: 7px; font-size: 12.5px; font-weight: 600; cursor: pointer; border: 1px solid var(--line); background: #fff; color: var(--ink-soft); text-decoration: none; }
  .btn-small.btn-edit { background: rgba(217,164,65,0.10); border-color: rgba(217,164,65,0.4); color: var(--gold-deep); }
  .btn-small.btn-edit:hover { background: rgba(217,164,65,0.2); }
  .btn-small.btn-soldout { background: rgba(156,59,44,0.07); border-color: rgba(156,59,44,0.25); color: var(--cherry-deep); }
  .btn-small.btn-soldout:hover { background: rgba(156,59,44,0.15); }
  .btn-small.btn-restock { background: rgba(62,125,79,0.10); border-color: rgba(62,125,79,0.3); color: var(--green-deep); }
  .btn-small.btn-restock:hover { background: rgba(62,125,79,0.2); }
  .btn-small.btn-trash { width: 32px; padding: 7px 0; display: inline-flex; align-items: center; justify-content: center; background: rgba(156,59,44,0.07); border-color: rgba(156,59,44,0.25); color: var(--cherry-deep); }
  .btn-small.btn-trash:hover { background: rgba(156,59,44,0.18); }
  .btn-small.btn-trash svg { width: 14px; height: 14px; }
  .empty-state { padding: 60px 20px; text-align: center; color: var(--ink-soft); }
  .empty-state h3 { font-size: 18px; color: var(--ink); margin-bottom: 6px; }
  .menu-layout { display: flex; gap: 20px; align-items: flex-start; }
  .menu-list { flex: 1; min-width: 0; }
  .menu-side { width: 400px; flex-shrink: 0; position: sticky; top: 24px; max-height: calc(100vh - 48px); overflow-y: auto; }
  .add-item-panel { background: #fff; border: 1px solid var(--line); border-radius: 14px; padding: 22px; }
  .add-item-panel h3 { display: flex; align-items: center; gap: 9px; margin-bottom: 16px; font-size: 17px; }
  .add-item-panel h3 svg { width: 19px; height: 19px; color: var(--gold-deep); }
  .add-item-form { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; align-items: end; }
  .add-item-form .field { margin: 0; }
  .add-item-form .span-2 { grid-column: span 2; }
  @media (max-width: 1100px) {
    .menu-layout { flex-direction: column; }
    .menu-side { width: 100%; position: static; max-height: none; }
  }
  .upload-square {
    position: relative; display: flex; align-items: center; justify-content: center;
    width: 170px; aspect-ratio: 1; margin: 0 auto; overflow: hidden;
    border: 1.5px dashed var(--line); border-radius: 12px; background: var(--parchment);
    cursor: pointer; color: var(--ink-soft); text-align: center;
  }
  .upload-square:hover { border-color: var(--gold); color: var(--gold-deep); }
  .upload-square img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; }
  .upload-square input { display: none; }
  .upload-hint { display: flex; flex-direction: column; align-items: center; gap: 5px; font-size: 11px; padding: 10px; }
  .upload-hint svg { width: 24px; height: 24px; }
  .upload-hint .upload-name { font-weight: 600; font-size: 12.5px; }
  .add-item-form textarea {
    width: 100%; padding: 11px 12px; border-radius: 8px; border: 1px solid var(--line);
    background: #fff; color: var(--ink); font-family: var(--font-body); font-size: 14.5px;
    resize: vertical; min-height: 76px;
  }
  .add-item-form textarea:focus { border-color: var(--gold); }
  @media (max-width: 900px) { .add-item-form { grid-template-columns: 1fr 1fr; } }
</style>
</head>
<body>
  <div class="app-shell">
    <%- include('partials-sidebar', { active: 'menu' }) %>

    <div class="app-main">
      <div class="app-topbar">
        <div>
          <h1 style="font-size:30px;">Menu</h1>
          <p class="menu-sub">Manage your menu items, prices, and availability.</p>
        </div>
      </div>
      <% if (error) { %><p class="order-error"><%= error %></p><% } %>

      <div class="menu-layout">
      <div class="menu-list">
      <% if (items.length === 0) { %>
        <div class="empty-state"><h3>No items yet</h3><p>Add your first menu item below.</p></div>
      <% } else { %>
        <%
          const categories = [...new Set(items.map((i) => i.category))];
          const catIcon = (cat) => {
            const c = cat.toLowerCase();
            if (/cake|dessert|torte/.test(c)) return 'cake';
            if (/bak|food|pastr|snack|bread|sandwich/.test(c)) return 'pastry';
            if (/tea|matcha/.test(c)) return 'leaf';
            return 'cup';
          };
        %>
        <% categories.forEach((cat) => { %>
          <% const catItems = items.filter((i) => i.category === cat); %>
          <div class="menu-section">
            <button type="button" class="menu-section-toggle">
              <% if (catIcon(cat) === 'cake') { %>
                <svg class="cat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M4 21v-4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v4"/><path d="M6.5 15v-2.5a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2V15"/><path d="M12 10.5V8.5"/><path d="M12 5.5c.7.8.7 1.7 0 2.5-.7-.8-.7-1.7 0-2.5z"/></svg>
              <% } else if (catIcon(cat) === 'pastry') { %>
                <svg class="cat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4c-5 0-9 5.5-9 9a3 3 0 0 0 3 3h12a3 3 0 0 0 3-3c0-3.5-4-9-9-9z"/><path d="M8.5 9.5c1-1.5 2.2-2.3 3.5-2.3s2.5.8 3.5 2.3"/></svg>
              <% } else if (catIcon(cat) === 'leaf') { %>
                <svg class="cat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 4 13c0-5 4-9 9-9a7 7 0 0 1 7 7c0 5-4 9-9 9z"/><path d="M4 21c4-4 7-6 12-8"/></svg>
              <% } else { %>
                <svg class="cat-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 8h13a3 3 0 0 1 0 6h-1"/><path d="M4 8v7a4 4 0 0 0 4 4h5a4 4 0 0 0 4-4V8"/></svg>
              <% } %>
              <%= cat %>
              <span class="count"><%= catItems.length %> item<%= catItems.length === 1 ? '' : 's' %></span>
              <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m18 15-6-6-6 6"/></svg>
            </button>
            <%
              const catTypes = new Set(catItems.map((i) => i.item_type));
              const sectionMode = catTypes.size === 1 ? [...catTypes][0] : 'mixed';
            %>
            <div class="menu-rows">
              <div class="menu-cols-head">
                <div class="col-thumb"></div>
                <div class="col-item">Item</div>
                <div class="col-status">Status</div>
                <div class="col-prices">
                <% if (sectionMode === 'drink') { %>
                  <div class="col-size">Small</div>
                  <div class="col-size">Medium</div>
                  <div class="col-size">Large</div>
                <% } else if (sectionMode === 'cake') { %>
                  <div class="col-wide">Slice</div>
                  <div class="col-wide">Whole</div>
                <% } else { %>
                  <div class="col-wide">Price</div>
                <% } %>
                </div>
                <div class="col-actions"></div>
              </div>
              <% catItems.forEach((item) => { %>
                <div class="menu-row <%= item.available ? '' : 'unavailable' %>">
                  <% const placeholder = item.item_type === 'food' ? '/img/placeholder-food.jpg' : '/img/placeholder-drink.jpg'; %>
                  <img class="menu-thumb" src="<%= item.image_url || placeholder %>" alt=""
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';">
                  <div class="menu-thumb-placeholder" style="display:none;"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 8h13a3 3 0 0 1 0 6h-1"/><path d="M4 8v7a4 4 0 0 0 4 4h5a4 4 0 0 0 4-4V8"/></svg></div>
                  <div class="menu-row-info">
                    <div class="menu-row-name"><%= item.name %></div>
                    <% if (item.note) { %><div class="menu-row-note"><%= item.note %></div><% } %>
                  </div>
                  <div class="col-status"><span class="status-pill <%= item.available ? '' : 'sold-out' %>"><%= item.available ? 'Available' : 'Sold out' %></span></div>
                  <div class="col-prices">
                  <% if (sectionMode === 'drink') { %>
                    <div class="col-size menu-row-price">$<%= item.price.toFixed(2) %></div>
                    <div class="col-size menu-row-price"><% if (item.price_medium) { %>$<%= item.price_medium.toFixed(2) %><% } else { %><span class="price-empty">&ndash;</span><% } %></div>
                    <div class="col-size menu-row-price"><% if (item.price_large) { %>$<%= item.price_large.toFixed(2) %><% } else { %><span class="price-empty">&ndash;</span><% } %></div>
                  <% } else if (sectionMode === 'cake') { %>
                    <div class="col-wide menu-row-price">$<%= item.price.toFixed(2) %></div>
                    <div class="col-wide menu-row-price"><% if (item.price_medium) { %>$<%= item.price_medium.toFixed(2) %><% } else { %><span class="price-empty">&ndash;</span><% } %></div>
                  <% } else if (sectionMode === 'food') { %>
                    <div class="col-wide menu-row-price">$<%= item.price.toFixed(2) %></div>
                  <% } else { %>
                    <div class="col-wide menu-row-price" style="width:auto;">$<%= item.price.toFixed(2) %><% if (item.price_medium) { %> / <%= item.price_medium.toFixed(2) %><% } %><% if (item.price_large) { %> / <%= item.price_large.toFixed(2) %><% } %></div>
                  <% } %>
                  </div>
                  <div class="menu-row-actions col-actions">
                    <a class="btn-small btn-edit" href="/menu/<%= item.id %>/edit">Edit</a>
                    <form method="POST" action="/menu/<%= item.id %>/toggle"><button type="submit" class="btn-small <%= item.available ? 'btn-soldout' : 'btn-restock' %>"><%= item.available ? 'Sold out' : 'Restock' %></button></form>
                    <form method="POST" action="/menu/<%= item.id %>/delete" class="delete-form" data-item-name="<%= item.name %>">
                      <button type="submit" class="btn-small btn-trash" aria-label="Remove <%= item.name %>">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                      </button>
                    </form>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      <% } %>
      </div>

      <div class="menu-side">
      <div class="add-item-panel" id="add-item-panel">
        <h3><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M4 8h13a3 3 0 0 1 0 6h-1"/><path d="M4 8v7a4 4 0 0 0 4 4h5a4 4 0 0 0 4-4V8"/></svg> Add a New Item</h3>
        <% const cats = [...new Set(items.map((i) => i.category))]; %>
        <% const isNewCat = values.category && !cats.includes(values.category); %>
        <form method="POST" action="/menu" class="add-item-form" enctype="multipart/form-data">
          <div class="field span-2"><label>Image</label>
            <label class="upload-square">
              <img id="upload-preview" alt="" hidden>
              <span class="upload-hint" id="upload-hint">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="3"/><circle cx="9" cy="9" r="2"/><path d="m21 15-4.6-4.6a1.5 1.5 0 0 0-2.1 0L5 20"/></svg>
                <span class="upload-name">Upload Image</span>
                <span>JPG, PNG or WEBP up to 5MB</span>
              </span>
              <input id="itemImage" name="itemImage" type="file" accept="image/jpeg,image/png,image/webp">
            </label>
          </div>
          <div class="field span-2"><label for="name">Name</label><input id="name" name="name" type="text" required placeholder="Enter item name" value="<%= values.name || '' %>"></div>
          <div class="field"><label for="categorySelect">Category</label>
            <select id="categorySelect" name="category">
              <% cats.forEach((c) => { %><option value="<%= c %>"<%= values.category === c ? ' selected' : '' %>><%= c %></option><% }) %>
              <option value="__new__"<%= isNewCat ? ' selected' : '' %>>New category…</option>
            </select>
            <input id="categoryNew" name="categoryNew" type="text" placeholder="New category name" style="<%= isNewCat ? '' : 'display:none;' %>margin-top:6px;" value="<%= isNewCat ? values.category : '' %>">
          </div>
          <div class="field"><label for="itemType">Type</label>
            <select id="itemType" name="itemType"><option value="drink" <%= values.itemType === 'drink' ? 'selected' : '' %>>Drink</option><option value="food" <%= values.itemType === 'food' ? 'selected' : '' %>>Food</option><option value="cake" <%= values.itemType === 'cake' ? 'selected' : '' %>>Cake</option></select>
          </div>
          <div class="field"><label for="price" id="price-label">Price (S / Base)</label><input id="price" name="price" type="number" step="0.01" min="0.01" required placeholder="0.00" value="<%= values.price || '' %>"></div>
          <div class="field" id="field-medium"><label for="priceMedium" id="medium-label">Price M</label><input id="priceMedium" name="priceMedium" type="number" step="0.01" min="0.01" placeholder="0.00" value="<%= values.priceMedium || '' %>"></div>
          <div class="field" id="field-large"><label for="priceLarge">Price L</label><input id="priceLarge" name="priceLarge" type="number" step="0.01" min="0.01" placeholder="0.00" value="<%= values.priceLarge || '' %>"></div>
          <div class="field span-2"><label for="note">Description</label><textarea id="note" name="note" rows="3" placeholder="Add a description (ingredients, details, etc.)"><%= values.note || '' %></textarea></div>
          <button type="submit" class="btn btn-primary span-2" style="margin:0;">Add Item</button>
        </form>
      </div>
      </div>
      </div>
    </div>
  </div>
  <script>
    document.querySelectorAll('.menu-section-toggle').forEach((btn) => {
      btn.addEventListener('click', () => btn.closest('.menu-section').classList.toggle('collapsed'));
    });
    document.querySelectorAll('.delete-form').forEach((form) => {
      form.addEventListener('submit', (e) => {
        if (!confirm('Remove "' + form.dataset.itemName + '" from the menu? This cannot be undone.')) e.preventDefault();
      });
    });

    const catSelect = document.getElementById('categorySelect');
    const catNew = document.getElementById('categoryNew');
    if (catSelect) {
      const syncCatSelect = () => {
        const isNew = catSelect.value === '__new__';
        catNew.style.display = isNew ? '' : 'none';
        if (isNew) { catSelect.removeAttribute('name'); catNew.setAttribute('name', 'category'); }
        else { catSelect.setAttribute('name', 'category'); catNew.removeAttribute('name'); }
      };
      catSelect.addEventListener('change', () => { syncCatSelect(); if (catSelect.value === '__new__') catNew.focus(); });
      syncCatSelect();
    }

    const typeSelect = document.getElementById('itemType');
    if (typeSelect) {
      const syncPriceFields = () => {
        const t = typeSelect.value;
        document.getElementById('price-label').textContent = t === 'cake' ? 'Price per slice' : (t === 'food' ? 'Price' : 'Price (S / Base)');
        document.getElementById('medium-label').textContent = t === 'cake' ? 'Whole cake' : 'Price M';
        document.getElementById('field-medium').style.display = t === 'food' ? 'none' : '';
        document.getElementById('field-large').style.display = t === 'drink' ? '' : 'none';
      };
      typeSelect.addEventListener('change', syncPriceFields);
      syncPriceFields();
    }

    const fileInput = document.getElementById('itemImage');
    if (fileInput) fileInput.addEventListener('change', () => {
      const file = fileInput.files[0];
      const preview = document.getElementById('upload-preview');
      const hint = document.getElementById('upload-hint');
      if (preview.src) URL.revokeObjectURL(preview.src);
      if (file) { preview.src = URL.createObjectURL(file); preview.hidden = false; hint.style.display = 'none'; }
      else { preview.removeAttribute('src'); preview.hidden = true; hint.style.display = ''; }
    });
  </script>
</body>
</html>
