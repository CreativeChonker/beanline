<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Work+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --espresso: #1c130d;
    --espresso-2: #2a1d14;
    --espresso-3: #3c2c1e;
    --parchment: #f7f0e3;
    --parchment-2: #efe4d0;
    --ink: #2a1c14;
    --ink-soft: #6b5847;
    --cream-ink: #f3e9d8;
    --cream-ink-soft: #c9b9a2;
    --gold: #d9a441;
    --gold-deep: #b9812a;
    --cherry: #9c3b2c;
    --cherry-deep: #7e2f22;
    --line: #ddcba9;

    --font-display: 'Fraunces', Georgia, serif;
    --font-body: 'Work Sans', -apple-system, Segoe UI, Roboto, Arial, sans-serif;
    --font-mono: 'IBM Plex Mono', ui-monospace, Menlo, monospace;
  }

  * { box-sizing: border-box; }
  html { -webkit-font-smoothing: antialiased; }
  body {
    margin: 0;
    font-family: var(--font-body);
    background: var(--espresso);
    color: var(--ink);
  }
  h1, h2, h3 { font-family: var(--font-display); margin: 0; font-weight: 600; }
  a { color: inherit; }

  *:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 2px;
  }

  ::selection { background: var(--gold); color: var(--espresso); }

  @media (prefers-reduced-motion: reduce) {
    * { animation-duration: 0.001ms !important; transition-duration: 0.001ms !important; }
  }

  /* ---- Shared entrance motion ---- */
  @keyframes rise {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .enter {
    opacity: 0;
    animation: rise 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  .enter-1 { animation-delay: 0.05s; }
  .enter-2 { animation-delay: 0.1s; }

  /* ---- Auth screens ---- */
  .auth-shell {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(circle at 20% 15%, rgba(217,164,65,0.10), transparent 45%),
      var(--espresso);
    padding: 24px;
  }
  .auth-card { width: 100%; max-width: 380px; }
  .auth-mark {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
    color: var(--cream-ink);
  }
  .auth-mark svg { width: 30px; height: 30px; color: var(--gold); }
  .auth-mark span {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 600;
    letter-spacing: 0.01em;
  }
  .panel {
    background: var(--parchment);
    border-radius: 14px;
    padding: 28px 26px;
    box-shadow: 0 24px 48px -20px rgba(0,0,0,0.55);
  }
  .panel h2 { font-size: 24px; margin-bottom: 4px; }
  .panel .sub { font-size: 14px; color: var(--ink-soft); margin: 0 0 20px; }
  .field { margin-top: 14px; }
  .field label {
    display: block;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    margin-bottom: 6px;
    font-weight: 600;
  }
  .field input, .field select {
    width: 100%;
    padding: 11px 12px;
    border-radius: 8px;
    border: 1px solid var(--line);
    background: #fff;
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 14.5px;
  }
  .field input:focus, .field select:focus { border-color: var(--gold); }
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: none;
    border-radius: 8px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 14.5px;
    cursor: pointer;
    padding: 12px 18px;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .btn-primary { background: var(--gold); color: var(--espresso); width: 100%; margin-top: 22px; }
  .btn-primary:hover { background: var(--gold-deep); }
  .btn-primary:active { transform: scale(0.98); }
  .panel-foot { margin-top: 18px; font-size: 13.5px; color: var(--ink-soft); text-align: center; }
  .panel-foot a { color: var(--cherry); font-weight: 600; text-decoration: none; }
  .panel-foot a:hover { text-decoration: underline; }
  .form-error {
    background: rgba(156,59,44,0.08);
    border: 1px solid rgba(156,59,44,0.3);
    color: var(--cherry-deep);
    font-size: 13.5px;
    padding: 10px 12px;
    border-radius: 8px;
    margin-bottom: 4px;
  }

  /* ---- App shell (order / dashboard) ---- */
  .app-shell { display: flex; min-height: 100vh; background: var(--parchment); }
  .app-sidebar {
    width: 216px;
    flex-shrink: 0;
    background: var(--espresso);
    color: var(--cream-ink);
    padding: 26px 18px;
    display: flex;
    flex-direction: column;
  }
  .app-mark { display: flex; align-items: center; gap: 9px; margin-bottom: 34px; padding-left: 4px; }
  .app-mark svg { width: 24px; height: 24px; color: var(--gold); }
  .app-mark span { font-family: var(--font-display); font-size: 17px; font-weight: 600; }
  .app-nav-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border-radius: 8px;
    color: var(--cream-ink-soft);
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 3px;
  }
  .app-nav-item.active { background: var(--espresso-2); color: var(--gold); font-weight: 600; }
  .app-sidebar-foot {
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--espresso-3);
    font-size: 13px;
  }
  .app-sidebar-foot .who { color: var(--cream-ink); font-weight: 600; margin-bottom: 6px; }
  .app-sidebar-foot a { color: var(--cream-ink-soft); text-decoration: none; }
  .app-sidebar-foot a:hover { color: var(--gold); }

  .app-main { flex: 1; padding: 30px 36px 48px; min-width: 0; }
  .app-topbar { display: flex; align-items: center; justify-content: space-between; gap: 20px; margin-bottom: 26px; }
  .app-search { flex: 1; max-width: 380px; position: relative; }
  .app-search svg {
    position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
    width: 15px; height: 15px; color: var(--ink-soft);
  }
  .app-search input {
    width: 100%;
    padding: 10px 14px 10px 36px;
    border-radius: 9px;
    border: 1px solid var(--line);
    background: #fff;
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--ink);
  }
  .app-search input:focus { border-color: var(--gold); }
  .app-user { display: flex; align-items: center; gap: 9px; font-size: 13.5px; color: var(--ink-soft); white-space: nowrap; }
  .avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--cherry); color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700; font-size: 13px; font-family: var(--font-display);
  }

  /* ---- Receipt signature motif ---- */
  .receipt {
    background: #fffdf8;
    border: 1px solid var(--line);
    border-bottom: none;
    padding: 20px 20px 26px;
    position: relative;
  }
  .receipt::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -1px;
    height: 12px;
    background:
      linear-gradient(-45deg, #fffdf8 6px, transparent 0),
      linear-gradient(45deg, #fffdf8 6px, transparent 0);
    background-size: 12px 12px;
    background-repeat: repeat-x;
  }
  .receipt h2 { font-size: 17px; letter-spacing: 0.01em; }
  .receipt-line {
    display: flex;
    align-items: baseline;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink);
    gap: 6px;
  }
  .receipt-line .dots { flex: 1; border-bottom: 1px dotted var(--line); transform: translateY(-3px); }
</style>
